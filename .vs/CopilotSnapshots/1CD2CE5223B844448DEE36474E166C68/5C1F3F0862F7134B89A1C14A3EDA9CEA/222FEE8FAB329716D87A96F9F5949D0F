#pragma once
#include "raylib.h"

class Vagon {
protected:
    Vector2 posicion;
    Texture2D textura;
    int valor;

public:
    Vagon(Vector2 pos, Texture2D tex, int val);
    ~Vagon();

    void Dibujar();

    // Getters y Setters
    Vector2 GetPosicion() { return posicion; }
    void SetPosicion(Vector2 pos) { posicion = pos; }
    int GetValor() { return valor; }
    Vector2 GetBox() { return { (float)textura.height,(float)textura.width }; }
};